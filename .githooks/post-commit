#!/usr/bin/env bash
# Auto-deploy the Node server when the just-made commit touched server/ or deploy.py.
# Runs detached so `git commit` returns instantly; log lives at /tmp/sneakbit-deploy.log.
#
# Install: `python3 deploy.py --install-hook` (sets git config core.hooksPath .githooks).
# Disable: `git config --unset core.hooksPath`.

set -e

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Branch guard: only deploy from main. Phase-* branches iterate on server/ code
# but should not hit the live VPS until merged. The check happens before the
# path filter so even a `.githooks/` commit on a feature branch is silent.
current_branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$current_branch" != "main" ]; then
  echo "[post-commit] on branch '$current_branch' (not main), skipping deploy"
  exit 0
fi

# First-commit safety: HEAD~1 doesn't exist on an initial commit, so diff against
# the empty tree to compare HEAD against "nothing".
if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
  range="HEAD~1 HEAD"
else
  range="$(git hash-object -t tree /dev/null) HEAD"
fi

changed="$(git diff --name-only $range)"

if echo "$changed" | grep -qE '^(server/|shared/|deploy\.py$|\.githooks/)'; then
  echo "[post-commit] server/shared changes detected — deploying in background"
  echo "[post-commit] tail -f /tmp/sneakbit-deploy.log to watch"
  # nohup + & detaches the deploy so `git commit` returns instantly. We used
  # to wrap with setsid for a fresh session, but macOS doesn't ship setsid by
  # default and the previous version silently failed — committed code didn't
  # deploy. nohup alone is portable across Linux + macOS.
  nohup python3 "$repo_root/deploy.py" \
    >> /tmp/sneakbit-deploy.log 2>&1 </dev/null &
  disown || true
else
  echo "[post-commit] no server changes, skipping deploy"
fi
